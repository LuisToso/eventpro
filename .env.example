# =============================================
# EventPro · Configuración (variables de entorno)
# =============================================
# Copia este fichero a .env y rellena los valores. NO subas .env al repo.

# Contraseña compartida del equipo para entrar a la app
APP_PASSWORD=cambia-esta-contrasena

# Secreto para firmar las cookies de sesión (usa una cadena larga aleatoria)
SESSION_SECRET=pon-aqui-una-cadena-aleatoria-larga

# URL pública (se usa en los emails de notificación)
BASE_URL=https://eventpro.tu-dominio.com

# Entorno (production activa cookies seguras)
NODE_ENV=production

# Puerto (opcional, por defecto 3000)
# PORT=3000

# =============================================
# Notificaciones por EMAIL (opcional)
# =============================================
# Para Gmail: crear una "Contraseña de aplicación"
# en https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-cuenta@gmail.com
SMTP_PASS=tu-app-password
SMTP_FROM=EventPro <tu-cuenta@gmail.com>

# =============================================
# Notificaciones por WHATSAPP (opcional, Twilio)
# =============================================
# 1. Crea cuenta en https://twilio.com
# 2. Activa el sandbox de WhatsApp en Messaging → Try It Out
# 3. Copia las credenciales aquí
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
